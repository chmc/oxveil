{
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "plansDirectory": "./.claude/plans",
  "permissions": {
    "allow": [
      "Edit(.claude/plans/**)",
      "Write(.claude/plans/**)",
      "Bash(touch .claude/workflow-state/*)",
      "Bash(rm .claude/workflow-state/*)",
      "Bash(rm -f .claude/workflow-state/*)",
      "Bash(mv .claude/workflow-state/* .claude/workflow-state/*)",
      "Bash(mkdir -p .claude/workflow-state*)",
      "Bash(echo * > .claude/workflow-state/*)",
      "Bash(cat .claude/workflow-state/*)",
      "Bash(ls .claude/workflow-state*)",
      "Bash(touch .claude/workflow-state/* && touch .claude/workflow-state/*)",
      "Bash(mkdir -p .claude/review-sessions/*)",
      "Bash(cat > .claude/review-sessions/*)",
      "Bash(rm -rf .claude/review-sessions/*)",
      "Bash(mkdir -p .claude/plans*)",
      "Bash(rm .claude/plans/*)",
      "Bash(set -o pipefail; ( cat * ) 2>&1 | awk *)",
      "Bash(set -o pipefail; ( grep * ) 2>&1 | awk *)",
      "Bash(set -o pipefail; ( find * ) 2>&1 | awk *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/task-hygiene-stop.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/exit-plan-mode.sh"
          }
        ]
      },
      {
        "matcher": "TaskCreate",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/tasks-created.sh"
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/taskupdate-success.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/bash-truncate.mjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Glob|Grep|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: STOP. Before exploring, read graphify-out/GRAPH_REPORT.md. For Agent spawns: include graphify context in prompt or use graphify query/path/explain instead of raw exploration.\"}}' || true"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/claudeloop-awareness.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/branch-awareness.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/planning-checklist.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/aleksi/Library/Caches/oxveil/oxveil-plan-intercept.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/plan-to-tasks.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/tdd-enforcement.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/state-sync-enforcement.sh"
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/completion-bundle.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/taskupdate-reminder.sh"
          }
        ]
      }
    ]
  }
}
