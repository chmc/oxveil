{
  "name": "oxveil",
  "displayName": "Oxveil",
  "description": "Manage AI coding workflows powered by claudeloop",
  "version": "0.1.0",
  "publisher": "chmc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chmc/oxveil"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/.claudeloop"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "claudeloop-plan",
        "aliases": ["Claudeloop Plan"],
        "filenames": ["PLAN.md"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "claudeloop-plan",
        "scopeName": "text.md.plan.oxveil",
        "path": "./syntaxes/plan.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "claudeloop-plan",
        "path": "./snippets/plan.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "oxveil",
          "title": "Oxveil",
          "icon": "$(symbol-event)"
        }
      ]
    },
    "views": {
      "oxveil": [
        {
          "type": "webview",
          "id": "oxveil.sidebar",
          "name": "Oxveil"
        }
      ]
    },
    "commands": [
      {
        "command": "oxveil.start",
        "title": "Oxveil: Start"
      },
      {
        "command": "oxveil.stop",
        "title": "Oxveil: Stop"
      },
      {
        "command": "oxveil.reset",
        "title": "Oxveil: Reset"
      },
      {
        "command": "oxveil.forceUnlock",
        "title": "Oxveil: Force Unlock"
      },
      {
        "command": "oxveil.install",
        "title": "Oxveil: Install claudeloop"
      },
      {
        "command": "oxveil.viewLog",
        "title": "Oxveil: View Phase Log"
      },
      {
        "command": "oxveil.archiveReplay",
        "title": "Replay",
        "icon": "$(open-preview)"
      },
      {
        "command": "oxveil.archiveTimeline",
        "title": "Show Timeline",
        "icon": "$(graph-line)"
      },
      {
        "command": "oxveil.archiveRestore",
        "title": "Restore",
        "icon": "$(history)"
      },
      {
        "command": "oxveil.archiveRefresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "oxveil.showDependencyGraph",
        "title": "Oxveil: Show Dependency Graph"
      },
      {
        "command": "oxveil.viewDiff",
        "title": "Oxveil: View Phase Diff"
      },
      {
        "command": "oxveil.openConfigWizard",
        "title": "Oxveil: Edit Config"
      },
      {
        "command": "oxveil.runFromPhase",
        "title": "Oxveil: Run from Phase"
      },
      {
        "command": "oxveil.markPhaseComplete",
        "title": "Oxveil: Mark Phase Complete"
      },
      {
        "command": "oxveil.openReplayViewer",
        "title": "Oxveil: Open Replay"
      },
      {
        "command": "oxveil.aiParsePlan",
        "title": "Oxveil: AI Parse Plan"
      },
      {
        "command": "oxveil.createPlan",
        "title": "Oxveil: Create Plan"
      },
      {
        "command": "oxveil.showTimeline",
        "title": "Oxveil: Show Timeline"
      },
      {
        "command": "oxveil.welcome",
        "title": "Oxveil: Welcome"
      },
      {
        "command": "oxveil.showLiveRun",
        "title": "Oxveil: Show Live Run"
      },
      {
        "command": "oxveil.showPlanPreview",
        "title": "Oxveil: Show Plan Preview"
      },
      {
        "command": "oxveil.openPlanChat",
        "title": "Oxveil: Plan Chat"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "oxveil.start",
          "when": "oxveil.detected && !oxveil.processRunning"
        },
        {
          "command": "oxveil.stop",
          "when": "oxveil.processRunning"
        },
        {
          "command": "oxveil.reset",
          "when": "oxveil.detected && !oxveil.processRunning"
        },
        {
          "command": "oxveil.forceUnlock",
          "when": "oxveil.detected"
        },
        {
          "command": "oxveil.install",
          "when": "!oxveil.detected"
        },
        {
          "command": "oxveil.showDependencyGraph"
        },
        {
          "command": "oxveil.openConfigWizard",
          "when": "oxveil.detected"
        },
        {
          "command": "oxveil.runFromPhase",
          "when": "oxveil.detected"
        },
        {
          "command": "oxveil.markPhaseComplete",
          "when": "oxveil.detected"
        },
        {
          "command": "oxveil.openReplayViewer",
          "when": "oxveil.detected"
        },
        {
          "command": "oxveil.aiParsePlan",
          "when": "oxveil.detected && !oxveil.processRunning"
        },
        {
          "command": "oxveil.createPlan"
        },
        {
          "command": "oxveil.showTimeline",
          "when": "oxveil.detected"
        },
        {
          "command": "oxveil.welcome"
        },
        {
          "command": "oxveil.archiveTimeline",
          "when": "false"
        },
        {
          "command": "oxveil.showLiveRun",
          "when": "oxveil.detected"
        },
        {
          "command": "oxveil.showPlanPreview"
        },
        {
          "command": "oxveil.openPlanChat",
          "when": "oxveil.claudeDetected"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "oxveil.welcome",
        "title": "Get Started with Oxveil",
        "description": "Set up and run your first AI coding workflow",
        "steps": [
          {
            "id": "detect",
            "title": "Detect claudeloop",
            "description": "Oxveil needs [claudeloop](https://github.com/chmc/claudeloop) to manage AI coding sessions.\n\n[Install claudeloop](command:oxveil.install)",
            "media": {
              "markdown": "./media/walkthrough/detect.md"
            },
            "completionEvents": [
              "onContext:oxveil.detected"
            ]
          },
          {
            "id": "configure",
            "title": "Configure your workflow",
            "description": "Customize claudeloop settings for your project — model, flags, and execution options.\n\n[Open Configuration Wizard](command:oxveil.openConfigWizard)",
            "media": {
              "markdown": "./media/walkthrough/configure.md"
            },
            "completionEvents": [
              "onCommand:oxveil.openConfigWizard"
            ]
          },
          {
            "id": "createPlan",
            "title": "Create your first plan",
            "description": "A plan file (`PLAN.md`) defines the phases claudeloop will execute.\n\n[Create PLAN.md](command:oxveil.createPlan)",
            "media": {
              "markdown": "./media/walkthrough/createPlan.md"
            },
            "completionEvents": [
              "onContext:oxveil.walkthrough.hasPlan"
            ]
          },
          {
            "id": "runSession",
            "title": "Run your first session",
            "description": "Launch claudeloop to execute your plan phase by phase.\n\n[Start claudeloop](command:oxveil.start)",
            "media": {
              "markdown": "./media/walkthrough/runSession.md"
            },
            "completionEvents": [
              "onContext:oxveil.walkthrough.hasRun"
            ]
          }
        ]
      }
    ],
    "configuration": {
      "title": "Oxveil",
      "properties": {
        "oxveil.claudeloopPath": {
          "type": "string",
          "default": "claudeloop",
          "description": "Path to claudeloop executable"
        },
        "oxveil.claudePath": {
          "type": "string",
          "default": "claude",
          "description": "Path to Claude CLI executable"
        },
        "oxveil.watchDebounceMs": {
          "type": "number",
          "default": 100,
          "description": "Debounce interval for file watcher events (ms)"
        },
        "oxveil.verify": {
          "type": "boolean",
          "default": true,
          "description": "Run verification after each phase (--verify)"
        },
        "oxveil.refactor": {
          "type": "boolean",
          "default": true,
          "description": "Run refactoring after each phase (--refactor)"
        },
        "oxveil.dryRun": {
          "type": "boolean",
          "default": false,
          "description": "Preview plan without executing (--dry-run)"
        },
        "oxveil.aiParse": {
          "type": "boolean",
          "default": true,
          "description": "Auto-parse plan into phases (--ai-parse)"
        },
        "oxveil.liveRunAutoOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open Live Run panel when a session starts"
        },
        "oxveil.liveRunDashboardCollapsed": {
          "type": "boolean",
          "default": false,
          "description": "Start with the dashboard section collapsed in the Live Run panel"
        },
        "oxveil.liveRunLogLines": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 10000,
          "description": "Maximum number of log lines to retain in the Live Run panel"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "package": "vsce package -o oxveil.vsix",
    "release:local": "vsce package -o oxveil.vsix && vsce publish --packagePath oxveil.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.100.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "@vscode/vsce": "^3.0.0",
    "vitest": "^3.0.0"
  }
}
