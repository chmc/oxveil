{
  "name": "oxveil",
  "displayName": "Oxveil",
  "description": "Manage AI coding workflows powered by claudeloop",
  "version": "0.1.0",
  "publisher": "chmc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chmc/oxveil"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/.claudeloop"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "claudeloop-plan",
        "aliases": ["Claudeloop Plan"],
        "filenames": ["PLAN.md"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "claudeloop-plan",
        "scopeName": "text.md.plan.oxveil",
        "path": "./syntaxes/plan.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "claudeloop-plan",
        "path": "./snippets/plan.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "oxveil",
          "title": "Oxveil",
          "icon": "$(symbol-event)"
        }
      ]
    },
    "views": {
      "oxveil": [
        {
          "id": "oxveil.phases",
          "name": "Phases"
        },
        {
          "id": "oxveil.archive",
          "name": "Past Runs"
        }
      ]
    },
    "commands": [
      {
        "command": "oxveil.start",
        "title": "Oxveil: Start"
      },
      {
        "command": "oxveil.stop",
        "title": "Oxveil: Stop"
      },
      {
        "command": "oxveil.reset",
        "title": "Oxveil: Reset"
      },
      {
        "command": "oxveil.forceUnlock",
        "title": "Oxveil: Force Unlock"
      },
      {
        "command": "oxveil.install",
        "title": "Oxveil: Install claudeloop"
      },
      {
        "command": "oxveil.viewLog",
        "title": "Oxveil: View Phase Log"
      },
      {
        "command": "oxveil.archiveReplay",
        "title": "Replay",
        "icon": "$(open-preview)"
      },
      {
        "command": "oxveil.archiveRestore",
        "title": "Restore",
        "icon": "$(history)"
      },
      {
        "command": "oxveil.archiveRefresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "oxveil.showDependencyGraph",
        "title": "Oxveil: Show Dependency Graph"
      },
      {
        "command": "oxveil.viewDiff",
        "title": "Oxveil: View Phase Diff"
      },
      {
        "command": "oxveil.openConfigWizard",
        "title": "Oxveil: Edit Config"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "oxveil.viewLog",
          "when": "view == oxveil.phases && viewItem =~ /^phase/",
          "group": "navigation"
        },
        {
          "command": "oxveil.viewDiff",
          "when": "view == oxveil.phases && viewItem == phase-completed",
          "group": "navigation"
        },
        {
          "command": "oxveil.archiveReplay",
          "when": "view == oxveil.archive && viewItem == archive",
          "group": "inline"
        },
        {
          "command": "oxveil.archiveRestore",
          "when": "view == oxveil.archive && viewItem == archive",
          "group": "inline"
        }
      ],
      "view/title": [
        {
          "command": "oxveil.archiveRefresh",
          "when": "view == oxveil.archive",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "oxveil.start",
          "when": "oxveil.detected && !oxveil.processRunning"
        },
        {
          "command": "oxveil.stop",
          "when": "oxveil.processRunning"
        },
        {
          "command": "oxveil.reset",
          "when": "oxveil.detected && !oxveil.processRunning"
        },
        {
          "command": "oxveil.forceUnlock",
          "when": "oxveil.detected"
        },
        {
          "command": "oxveil.install",
          "when": "!oxveil.detected"
        },
        {
          "command": "oxveil.showDependencyGraph"
        },
        {
          "command": "oxveil.openConfigWizard",
          "when": "oxveil.detected"
        }
      ]
    },
    "configuration": {
      "title": "Oxveil",
      "properties": {
        "oxveil.claudeloopPath": {
          "type": "string",
          "default": "claudeloop",
          "description": "Path to claudeloop executable"
        },
        "oxveil.watchDebounceMs": {
          "type": "number",
          "default": 100,
          "description": "Debounce interval for file watcher events (ms)"
        },
        "oxveil.verify": {
          "type": "boolean",
          "default": true,
          "description": "Run verification after each phase (--verify)"
        },
        "oxveil.refactor": {
          "type": "boolean",
          "default": true,
          "description": "Run refactoring after each phase (--refactor)"
        },
        "oxveil.dryRun": {
          "type": "boolean",
          "default": false,
          "description": "Preview plan without executing (--dry-run)"
        },
        "oxveil.aiParse": {
          "type": "boolean",
          "default": true,
          "description": "Auto-parse plan into phases (--ai-parse)"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "package": "vsce package -o oxveil.vsix",
    "release:local": "vsce package -o oxveil.vsix && vsce publish --packagePath oxveil.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.100.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "@vscode/vsce": "^3.0.0",
    "vitest": "^3.0.0"
  }
}
